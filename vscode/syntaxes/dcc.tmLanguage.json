{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "DCC",
    "scopeName": "source.dc",
    "fileTypes": [
        "dc"
    ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#chars"
        },
        {
            "include": "#attributes"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.dc",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.dc",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "include": "#comments"
                        }
                    ]
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.dc",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.dc",
                    "match": "\\\\."
                }
            ]
        },
        "chars": {
            "name": "string.quoted.single.dc",
            "match": "'(?:[^'\\\\]|\\\\.)'",
            "captures": {
                "0": {
                    "patterns": [
                        {
                            "include": "#char_escape"
                        }
                    ]
                }
            }
        },
        "char_escape": {
            "name": "constant.character.escape.dc",
            "match": "\\\\."
        },
        "attributes": {
            "name": "keyword.other.attribute.dc",
            "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.dc",
                    "match": "\\b0[xX][0-9a-fA-F_]+(?:\\.[0-9a-fA-F_]+)?(?:[pP][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.binary.dc",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.dc",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.dc",
                    "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9][0-9_]*)?([fF](?:32|64))?\\b"
                },
                {
                    "name": "constant.numeric.integer.dc",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.dc",
                    "match": "\\b(?:if|else|while|for|do|match|break|continue|return|defer|as|in)\\b"
                },
                {
                    "name": "keyword.other.dc",
                    "match": "\\b(?:module|import|public|struct|enum|union|using|const|restrict|volatile|static|extern|sizeof|alignof|offsetof|compiles)\\b"
                }
            ]
        },
        "types": {
            "name": "storage.type.dc",
            "match": "\\b(?:u8|i8|u16|i16|u32|i32|u64|i64|f32|f64|char|bool|void|null_t)\\b"
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.dc",
                    "match": "\\b(?:null|true|false)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.dc",
                    "match": "->|=>|::|\\+\\+|--|&&|\\|\\||==|!=|<=|>=|<<|>>|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
                },
                {
                    "name": "keyword.operator.dc",
                    "match": "[+\\-*/%=<>!&|^~.?]"
                }
            ]
        },
        "identifiers": {
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
    }
}
