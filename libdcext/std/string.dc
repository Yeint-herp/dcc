module std::string;

public i64 lfind([] const char str, char ch) {
    for u64 i = 0;
    i < str.len;
    i++ {
        if str[i] == ch {
            return i;
        }
    }

    return - 1;
}

public u64 len(const u8* s) {
    u64 n = 0;
    while s[n] != 0 {
        n++;
    }

    return n;
}

public u64 len(const char* s) {
    u64 n = 0;
    while s[n] != 0 as char {
        n++;
    }

    return n;
}

public u64 len([] const char s) {
    return s.len;
}
