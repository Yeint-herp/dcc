module std::string;

public i64 lfind([] const char str, char ch) {
    for usize i = 0;
    i < str.len;
    i++ {
        if str[i] == ch {
            return i as i64;
        }
    }

    return - 1;
}

public usize len(const u8* s) {
    usize n = 0;
    while s[n] != 0 {
        n++;
    }

    return n;
}

public usize len(const char* s) {
    usize n = 0;
    while s[n] != 0 as char {
        n++;
    }

    return n;
}

public usize len([] const char s) {
    return s.len;
}
