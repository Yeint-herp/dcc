=== FILE: test.dc ===
module test;

@nomangle
public i32 if_expr_i32(bool cond) {
    return if cond { 10 } else { 20 };
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-elf"

define i32 @if_expr_i32(i1 %cond) {
entry:
  br i1 %cond, label %if.then1, label %if.else2

if.then1:                                         ; preds = %entry
  br label %if.merge3

if.else2:                                         ; preds = %entry
  br label %if.merge3

if.merge3:                                        ; preds = %if.else2, %if.then1
  %"0" = phi i32 [ 10, %if.then1 ], [ 20, %if.else2 ]
  ret i32 %"0"
}
