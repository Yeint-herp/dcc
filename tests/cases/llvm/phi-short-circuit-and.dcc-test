=== FILE: test.dc ===
module test;

@nomangle
public bool sc_and(bool a, bool b) {
    return a && b;
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-unknown-linux-gnu"

define i1 @sc_and(i1 %a, i1 %b) {
entry:
  br i1 %a, label %sc.rhs1, label %sc.merge2

sc.rhs1:                                          ; preds = %entry
  br label %sc.merge2

sc.merge2:                                        ; preds = %sc.rhs1, %entry
  %"0" = phi i1 [ false, %entry ], [ %b, %sc.rhs1 ]
  ret i1 %"0"
}
