=== FILE: test.dc ===
module test;

public enum Result(T, E) { Ok(T), Err(E), }

public i32 unwrap_or(Result(i32, i32) x, i32 fallback) {
    return match x {
        Result::Ok(v) => v,
        Result::Err(_) => fallback,
    };
}

public i32 accumulate(T...)(T args) {
    i32 total = 0;
    static for arg in args {
        total = total + arg;
    }

    return total;
}

@nomangle
public i32 test_caller() {
    i32 a = accumulate(10, 20, 30);
    return a;
}

