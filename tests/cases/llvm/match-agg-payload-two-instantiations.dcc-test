=== FILE: test.dc ===
module test;

public struct Box(T) {
    T value;
}

public enum Option(T) { Some(T), None, }

@nomangle
public i32 get_i32(Option(Box(i32)) x) {
    return match x {
        Option::Some(b) => b.value,
        Option::None => 0,
    };
}

@nomangle
public i64 get_i64(Option(Box(i64)) x) {
    return match x {
        Option::Some(b) => b.value,
        Option::None => 0,
    };
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-unknown-linux-gnu"

%0 = type { i8, [3 x i8], [4 x i8] }
%1 = type { i32 }
%2 = type { i8, [7 x i8], [8 x i8] }
%3 = type { i64 }

define i32 @get_i32(%0 %x) {
entry:
  %"0" = alloca %0, align 8
  store %0 %x, ptr %"0", align 1
  %"1" = load %0, ptr %"0", align 1
  br label %match.arm0.test3

match.merge1:                                     ; preds = %match.arm1.body6, %match.arm0.body4
  %"13" = phi i32 [ %"10", %match.arm0.body4 ], [ 0, %match.arm1.body6 ]
  ret i32 %"13"

match.fail2:                                      ; preds = %match.arm1.test5
  unreachable

match.arm0.test3:                                 ; preds = %entry
  %"2" = extractvalue %0 %"1", 0
  %"3" = icmp eq i8 %"2", 0
  br i1 %"3", label %match.arm0.body4, label %match.arm1.test5

match.arm0.body4:                                 ; preds = %match.arm0.test3
  %"4" = extractvalue %0 %"1", 2
  %"6" = alloca [4 x i8], align 1
  store [4 x i8] %"4", ptr %"6", align 1
  %"7" = load %1, ptr %"6", align 4
  %"8" = alloca %1, align 8
  store %1 %"7", ptr %"8", align 4
  %"9" = load %1, ptr %"8", align 4
  %"10" = extractvalue %1 %"9", 0
  br label %match.merge1

match.arm1.test5:                                 ; preds = %match.arm0.test3
  %"11" = extractvalue %0 %"1", 0
  %"12" = icmp eq i8 %"11", 1
  br i1 %"12", label %match.arm1.body6, label %match.fail2

match.arm1.body6:                                 ; preds = %match.arm1.test5
  br label %match.merge1
}

define i64 @get_i64(%2 %x) {
