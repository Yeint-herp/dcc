=== FILE: test.dc ===
module test;
import core::atomic;

public i32 test_exchange_seqcst(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_exchange(ptr, v, core::atomic::MemoryOrder::SeqCst);
}

public i32 test_fetch_add_relaxed(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_fetch_add(ptr, v, core::atomic::MemoryOrder::Relaxed);
}

public i32 test_fetch_sub_acquire(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_fetch_sub(ptr, v, core::atomic::MemoryOrder::Acquire);
}

public i32 test_fetch_and_release(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_fetch_and(ptr, v, core::atomic::MemoryOrder::Release);
}

public i32 test_fetch_or_acqrel(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_fetch_or(ptr, v, core::atomic::MemoryOrder::AcqRel);
}

public i32 test_fetch_xor_seqcst(volatile i32* ptr, i32 v) {
    return core::atomic::atomic_fetch_xor(ptr, v, core::atomic::MemoryOrder::SeqCst);
}

public void test_fence_acquire() {
    core::atomic::atomic_fence(core::atomic::MemoryOrder::Acquire);
}

public void test_fence_release() {
    core::atomic::atomic_fence(core::atomic::MemoryOrder::Release);
}

public void test_fence_seqcst() {
    core::atomic::atomic_fence(core::atomic::MemoryOrder::SeqCst);
}

