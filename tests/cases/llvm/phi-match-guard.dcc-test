=== FILE: test.dc ===
module test;

public enum Option(T) { Some(T), None, }

@nomangle
public i32 f(Option(i32) x) {
    return match x {
        Option::Some(v) if v > 0 => v,
        Option::Some(v) => 0,
        Option::None => -1,
    };
}

