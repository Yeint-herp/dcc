=== FILE: test.dc ===
module test;

public enum Option(T) { Some(T), None, }

@nomangle
public i32 f(Option(Option(i32)) x) {
    return match x {
        Option::Some(inner) => match inner {
            Option::Some(v) => v,
            Option::None => -1,
        },
        Option::None => -2,
    };
}

