=== FILE: test.dc ===
module test;

public struct Box(T) {
    T value;
}

public enum Result(T, E) { Ok(T), Err(E), }

@nomangle
public i64 f(Result(Box(i32), Box(i64)) x) {
    return match x {
        Result::Ok(b) => b.value as i64,
        Result::Err(b) => b.value,
    };
}

