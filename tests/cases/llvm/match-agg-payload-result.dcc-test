  %"7" = load %1, ptr %"6", align 4
  %"8" = alloca %1, align 8
  store %1 %"7", ptr %"8", align 4
  %"9" = load %1, ptr %"8", align 4
  %"10" = extractvalue %1 %"9", 0
  %"11" = sext i32 %"10" to i64
  br label %match.merge1

match.arm1.test5:                                 ; preds = %match.arm0.test3
  %"12" = extractvalue %0 %"1", 0
  %"13" = icmp eq i8 %"12", 1
  br i1 %"13", label %match.arm1.body6, label %match.fail2

match.arm1.body6:                                 ; preds = %match.arm1.test5
