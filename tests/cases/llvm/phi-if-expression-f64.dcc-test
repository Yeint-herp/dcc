=== FILE: test.dc ===
module test;

@nomangle
public f64 if_expr_f64(bool cond) {
    return if cond { 1.0 } else { 2.0 };
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-unknown-linux-gnu"

define double @if_expr_f64(i1 %cond) {
entry:
  br i1 %cond, label %if.then1, label %if.else2

if.then1:                                         ; preds = %entry
  br label %if.merge3

if.else2:                                         ; preds = %entry
  br label %if.merge3

if.merge3:                                        ; preds = %if.else2, %if.then1
  %"0" = phi double [ 1.000000e+00, %if.then1 ], [ 2.000000e+00, %if.else2 ]
  ret double %"0"
}
