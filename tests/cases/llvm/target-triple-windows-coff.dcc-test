=== FILE: test.dc ===
module test;

@nomangle
public i32 add(i32 a, i32 b) { return a + b; }

=== EXPECT-LLVM FLAGS: -target x86_64-coff -verify ===
; ModuleID = 'test'
source_filename = "test"
