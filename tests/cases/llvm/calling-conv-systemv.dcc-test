=== FILE: test.dc ===
module test;

@calling_conv("systemv")
@nomangle
public i32 sysv_func(i32 x) {
    return x + 1;
}

@nomangle
public i32 call_sysv_func(i32 x) {
    return sysv_func(x);
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-unknown-linux-gnu"

define x86_64_sysvcc i32 @sysv_func(i32 %x) {
entry:
  %"0" = add i32 %x, 1
  ret i32 %"0"
}

define i32 @call_sysv_func(i32 %x) {
entry:
  %"0" = call x86_64_sysvcc i32 @sysv_func(i32 %x)
  ret i32 %"0"
}
