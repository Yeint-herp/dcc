=== FILE: test.dc ===
module test;

@nomangle
public bool load_bool(bool* p, i64 idx) {
    return p[idx];
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-elf"

define i1 @load_bool(ptr %p, i64 %idx) {
entry:
  %"0" = getelementptr i8, ptr %p, i64 %idx
  %0 = load i8, ptr %"0", align 1
  %"1" = trunc i8 %0 to i1
  ret i1 %"1"
}
