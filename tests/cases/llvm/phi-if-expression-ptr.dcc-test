=== FILE: test.dc ===
module test;

@nomangle
public i32* if_expr_ptr(bool cond) {
    return if cond { null } else { null };
}

=== EXPECT-LLVM FLAGS: -verify ===
; ModuleID = 'test'
source_filename = "test"
target triple = "x86_64-elf"

define ptr @if_expr_ptr(i1 %cond) {
entry:
  br i1 %cond, label %if.then1, label %if.else2

if.then1:                                         ; preds = %entry
  br label %if.merge3

if.else2:                                         ; preds = %entry
  br label %if.merge3

if.merge3:                                        ; preds = %if.else2, %if.then1
  %"0" = phi ptr [ null, %if.then1 ], [ null, %if.else2 ]
  ret ptr %"0"
}
