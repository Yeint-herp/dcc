=== FILE: test.dc ===
module test;

import core::atomic;

using AtomicLoadable(T) = compiles(core::atomic::Atomic(T)* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::Relaxed);
};

struct Slot(T) if AtomicLoadable(T) {
    core::atomic::Atomic(T) cell;
}

i32 load_cell() {
    Slot(i32) s;
    return core::atomic::atomic_load(&s.cell, core::atomic::MemoryOrder::Relaxed);
}

