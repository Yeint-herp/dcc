module test;

public i32 if_stmt(i32 x) {
    i32 r = 0;
    if (x) { r = 1; }
    return r;
}

public i32 if_else_stmt(i32 x) {
    i32 r = 0;
    if (x) { r = 10; } else { r = 20; }
    return r;
}

public i32 if_return(i32 x) {
    if (x) { return 10; } else { return 20; }
}

