define i64 @get_y_at(ptr %p, i64 %idx) {
entry:
  %"0" = getelementptr %0, ptr %p, i64 %idx
  %"1" = load %0, ptr %"0", align 4
  %"2" = extractvalue %0 %"1", 1
  ret i64 %"2"
}
