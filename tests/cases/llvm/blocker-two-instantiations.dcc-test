module test;

public enum Option(T) { Some(T), None, }

public void use_i32(i32 x) {}
public void use_i64(i64 x) {}

public void g_i32(Option(i32) x) {
    match x {
        Option::Some(v) => use_i32(v),
        Option::None => {},
    };
}

public void g_i64(Option(i64) x) {
    match x {
        Option::Some(v) => use_i64(v),
        Option::None => {},
    };
}

