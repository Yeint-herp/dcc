=== FILE: main.dc ===
module m;

struct A {
    B b;
    i32 y;
}

struct B {
    i32 x;
}

void f(A a) {
    sizeof(A);
    alignof(A);
    offsetof(A, b);
    offsetof(A, y);
    a.b.x;
}

