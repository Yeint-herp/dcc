module m;

struct Point {
    i32 x;
    i32 y;
}

enum Choice {
    @implicit_construction Some(i32),
    None,
}

i32 choose(Point p) {
    return 1;
}

i64 choose(i32[2] p) {
    return 2;
}

bool choose([]i32 p) {
    return false;
}

i64 choose_seq(i32[2] p) {
    return 2;
}

bool choose_seq([]i32 p) {
    return false;
}

bool choose_slice([]i32 p) {
    return false;
}

i32 use_struct() {
    Point p = { 1, 2 };
    return 1;
}

i64 use_array() {
    i32[2] values = { 3, 4 };
    return 2;
}

bool use_slice() {
    []i32 values = { 5, 6 };
    return false;
}

Choice use_enum() {
    Choice c = { 7 };
    return c;
}

i32 rank_struct() {
    return choose({ 1, 2 });
}

i64 rank_array() {
    return choose_seq({ 1, 2 });
}

bool rank_slice() {
    return choose_slice({ 1, 2 });
}

