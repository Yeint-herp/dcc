module m;

public struct S {
    i32 value;
}

i64 inspect(const S* s) {
    return 2;
}

i32 both_const(const S* s) {
    return 3;
}

i64 both_mut(S* s) {
    return 4;
}

public i64 mutable_prefers_mutable(S s) {
    return s.both_mut();
}

public i32 const_prefers_const(const S* s) {
    return s.both_const();
}

public i64 mutable_can_call_const(S s) {
    return s.inspect();
}

public i64 const_can_call_const(const S* s) {
    return s.inspect();
}

