module test;

public enum Result(T, E) { Ok(T), Err(E), }

public void test_reject_ok_arg() {
    Result(void, i32) r = Result::Ok(1);
}

public void test_reject_ok_block() {
    Result(void, i32) r = Result::Ok({});
}

public void test_reject_ok_wildcard(Result(void, i32) x) {
    match x {
        Result::Ok(_) => {},
        Result::Err(e) => {},
    };
}

public void test_reject_ok_binding(Result(void, i32) x) {
    match x {
        Result::Ok(v) => {},
        Result::Err(e) => {},
    };
}

