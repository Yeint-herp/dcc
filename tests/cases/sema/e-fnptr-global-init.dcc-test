module m;

using BinOp = i32(*)(i32, i32);

i32 add(i32 a, i32 b) { return a + b; }

BinOp g1 = add;
BinOp g2 = &add;

void test_read_globals() {
    BinOp r1 = g1;
    BinOp r2 = g2;
}

