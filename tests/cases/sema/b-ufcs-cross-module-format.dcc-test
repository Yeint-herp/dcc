module fmt;

public enum FormatArg {
    @implicit_construction Str([]const char),
    @implicit_construction Int(i32),
    @implicit_construction Uint(u64),
}

using WritableInto(T) = compiles (T x) {
    x.write("H");
    x.write('H');
};

public void print(T)(T out, []const char msg) {
}

public void print(T)(T out, []const char fmt, []const FormatArg args) if WritableInto(T) {
}

=== FILE: main.dc ===
module main;
import fmt;

struct MyOut {
    i32 fd;
}

void write(MyOut o, []const char s) {}
void write(MyOut o, char c) {}

i32 test_cross_module_format() {
    MyOut out;
    out.print("Advanced hello {}", {"world"});
    out.print("plain message");
    return 0;
}

void test_mixed() {
    MyOut out;
    out.print("mixed {}", {"a", 42, 7 as u64});
}

void test_empty_brace() {
    MyOut out;
    out.print("empty!");
}

