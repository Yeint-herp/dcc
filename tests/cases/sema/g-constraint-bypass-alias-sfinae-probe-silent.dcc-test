module m;

using IsInt(T) = compiles(T x) {
    x + 1;
};

struct X(T) if IsInt(T) {
    T val;
}

struct Bad {}

using A = X(Bad);

using HasBadAlias(T) = compiles(T x) {
    A a;
};

void f() {
    i32 val = 0;
    static if compiles {
        HasBadAlias(i32) result;
    } {
        val = 1;
    }
}
