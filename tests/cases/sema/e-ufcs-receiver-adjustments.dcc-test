module m;

public struct S {
    i32 value;
}

i32 pref_exact(S s) {
    return 1;
}

i64 pref_exact(S* s) {
    return 2;
}

public i32 exact_beats_auto_ref(S s) {
    return s.pref_exact();
}

i64 auto_ref_only(S* s) {
    return 3;
}

public i64 auto_ref_works(S s) {
    return s.auto_ref_only();
}

i64 ptr_pref(S* s) {
    return 4;
}

bool ptr_pref(const S* s) {
    return false;
}

public i64 mutable_pointer_wins(S s) {
    return s.ptr_pref();
}

i32 const_exact(const S* s) {
    return 5;
}

public i32 const_pointer_exact(const S* s) {
    return s.const_exact();
}

i32 deref_only(S s) {
    return 6;
}

public i32 auto_deref_works(S* s) {
    return s.deref_only();
}

