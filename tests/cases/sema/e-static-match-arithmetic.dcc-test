module m;

i32 f_static_match_add() {
    static match 40 + 2 {
        42 => return 1,
        _ => return 0,
    }
    return -1;
}

i32 f_static_match_mul() {
    static match 6 * 7 {
        42 => return 2,
        _ => return -1,
    }
    return -2;
}

i32 f_static_match_bitwise() {
    static match 6 & 3 {
        2 => return 3,
        _ => return -1,
    }
    return -3;
}

i32 f_static_match_shl() {
    static match 1 << 3 {
        8 => return 4,
        _ => return -1,
    }
    return -4;
}

i32 f_static_match_cmp() {
    i32 val = 100;
    static match val {
        100 => return 5,
        _ => return -1,
    }
    return -5;
}

