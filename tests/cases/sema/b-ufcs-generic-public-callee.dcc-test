module main;

using Formattable(T) = compiles (T x) {
    x.write("");
    x.write('\0');
};

public void format_impl(T)(T out, []const char fmt, []const char args) if Formattable(T) {
    out.write(fmt);
    out.write(args);
}

public void print(T)(T out, []const char fmt, []const char args) if Formattable(T) {
    out.format_impl(fmt, args);
}

struct ConOut { i32 fd; }

void write(ConOut o, []const char s) {}
void write(ConOut o, char c) {}

i32 test_generic_ufcs_public_callee() {
    ConOut out;
    out.print("hello {}", "world");
    return 0;
}

