=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

struct Envelope {
    Maybe maybe;
    Point point;
}

struct PairFields {
    Point point;
    Maybe maybe;
}

enum Packet {
    Pair(PairFields),
    Wrap(Envelope),
    Empty,
}

i64 score(Packet packet) {
    return match packet {
        Packet::Pair(PairFields { point => Point { x, y }, maybe => Maybe::Some(extra) }) if x < y && extra > 0 => (x + y + extra) as i64,
        Packet::Wrap(Envelope { maybe => Maybe::Some(code), point => Point { x => left, y => right } }) if code > left && right > 0 => (code + left + right) as i64,
        _ => 0,
    };
}

