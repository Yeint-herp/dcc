=== FILE: main.dc ===
module m;

u64 sz_return(T...)(T x) {
    return sizeof...(T);
}

void sz_expr(T...)(T x) {
    sizeof...(T);
}

bool sz_cmp(T...)(T x) {
    return sizeof...(T) == 1;
}

void sf_multi(T...)(T x) {
    static for item in x {
        item;
    }
}

void caller() {
    sz_return!(i32)(42);
    sz_expr!(i32, i64)(0, 1);
    sz_cmp!(i32, i64, f64)(0, 1, 2.0);
    sf_multi!(i32, i64, f64)(0, 1, 2.0);
}

