module m;

public struct S {
    i32 value;
}

i32 double_val(S s) {
    return s.value * 2;
}

i32 triple_val(S s) {
    return s.value * 3;
}

public i32 test_ufcs_registry() {
    S x = S{10};
    return x.double_val() + x.triple_val();
}

