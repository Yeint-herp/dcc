module m;

using IsInt(T) = compiles(T x) {
    x + 1;
};

struct Box(T) if IsInt(T) {
    T value;
}

@nominal using MyBox = Box(i32);

@nominal using BadBox = Box(Bad);

struct Bad {}

void f() {
    sizeof(MyBox);
    sizeof(BadBox);
}

