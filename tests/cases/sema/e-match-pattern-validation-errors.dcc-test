=== FILE: main.dc ===
module m;

enum Result {
    Ok(i32),
    Err(i32),
}

enum Other {
    X(i32),
}

struct Point {
    i32 x;
    i32 y;
}

i64 bad_variant(Result r) {
    return match r {
        Result::Missing => 0,
        _ => 1,
    };
}

i64 bad_payload(Result r) {
    return match r {
        Result::Ok() => 0,
        _ => 1,
    };
}

i64 bad_wrong_enum(Result r) {
    return match r {
        Other::X(v) => 0,
        _ => 1,
    };
}

i64 bad_field(Point p) {
    return match p {
        Point { z } => 0,
        _ => 1,
    };
}

i64 bad_struct(Result r) {
    return match r {
        Point { x } => 0,
        _ => 1,
    };
}

i64 bad_range(bool v) {
    return match v {
        false..=true => 0,
        _ => 1,
    };
}

i64 bad_or(i64 v) {
    return match v {
        x | y => 0,
        _ => 1,
    };
}

void bad_static(i64 v) {
    static match v {
        1 => 0,
        _ => 1,
    }
}

