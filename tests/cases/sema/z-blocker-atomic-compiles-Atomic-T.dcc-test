module m;

import core::atomic;

using AtomicLoadable(T) = compiles(core::atomic::Atomic(T)* p) {};

void accept(T)(core::atomic::Atomic(T)* p) if AtomicLoadable(T) {}

void test() {
    core::atomic::Atomic(i32) cell;
    core::atomic::Atomic(i32)* p = &cell;
    accept(p);
}
