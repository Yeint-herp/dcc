=== FILE: util.dc ===
module util;

public struct Point {
    i32 x;
    i32 y;
}

public i32 dist(Point p) {
    return p.x;
}

=== FILE: main.dc ===
module main;
import util;

i32 use_ufcs(util::Point p) {
    return p.dist();
}

