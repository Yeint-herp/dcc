module m;

public struct Empty {}

public union Nothing {}

public enum Plain {}

public enum Backed : u8 {
    A,
    B,
}

public struct SomePayload {
    u8 a;
    Empty b;
    u8[0] c;
}

public struct PairPayload {
    Nothing* a;
    Backed b;
}

public enum Tagged : u16 {
    None,
    Some(SomePayload),
    Pair(PairPayload),
}

public Empty empty;
public Nothing nothing;
public Plain plain;
public Backed backed;
public Tagged tagged;

