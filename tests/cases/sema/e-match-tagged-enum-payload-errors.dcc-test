module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

enum Node {
    Leaf(i32),
    Pair(Point, Maybe),
    Empty,
}

i64 bad(Node n) {
    return match n {
        Node::Leaf() => 0,
        Node::Pair(Point { x }, Maybe::Some(v, w)) => 1,
        Maybe::None => 2,
        _ => 3,
    };
}

