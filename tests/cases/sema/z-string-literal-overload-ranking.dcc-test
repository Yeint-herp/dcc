module m;

i32 pick([]const char x) { return 1; }
i64 pick([]const u8 x) { return 2; }

i32 test_char_slice_beats_u8_slice() {
    return pick("hello");
}

i32 pick2([]const char x) { return 1; }
i64 pick2(const char* x) { return 2; }

i32 test_slice_beats_pointer() {
    return pick2("hello");
}

i32 pick3([]const char x) { return 1; }
i64 pick3([]char x) { return 2; }

i32 test_const_slice_beats_mutable() {
    return pick3("hello");
}

i32 pick4([]const u8 x) { return 1; }
i64 pick4(const u8* x) { return 2; }

i32 test_u8_slice_beats_u8_pointer() {
    return pick4("hello");
}

