module test;

public enum Result(T, E) { Ok(T), Err(E), }

public void test_ok_no_args() {
    Result(i32, i32) r = Result::Ok();
}

public void test_ok_too_many(i32 a, i32 b) {
    Result(i32, i32) r = Result::Ok(a, b);
}

public void test_err_no_args() {
    Result(i32, i32) r = Result::Err();
}

