module m;

void test_basic_range_slice(i32[10] arr) {
    arr[1..3];
}

void test_omitted_start(i32[10] arr) {
    arr[..5];
}

void test_omitted_end(i32[10] arr) {
    arr[2..];
}

void test_omitted_both(i32[10] arr) {
    arr[..];
}

void test_inclusive(i32[10] arr) {
    arr[1..=3];
}

void test_inclusive_omitted_start(i32[10] arr) {
    arr[..=5];
}

void test_variable_bounds(i32[10] arr, i32 start, i32 end) {
    arr[start..end];
}

void test_slice_slice([]i32 sl, i32 a, i32 b) {
    sl[a..b];
}

void test_normal_index_still_works(i32[10] arr, i32 idx) {
    arr[idx];
    arr[0];
}

