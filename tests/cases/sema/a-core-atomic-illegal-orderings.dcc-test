=== FILE: main.dc ===
module main;
import core::atomic;

volatile i32 g;

void test_illegal_load_order_2() {
    core::atomic::atomic_load(&g, core::atomic::MemoryOrder::Release);
}

void test_illegal_load_order_3() {
    core::atomic::atomic_load(&g, core::atomic::MemoryOrder::AcqRel);
}

void test_illegal_store_order_1() {
    core::atomic::atomic_store(&g, 42, core::atomic::MemoryOrder::Acquire);
}

void test_illegal_store_order_3() {
    core::atomic::atomic_store(&g, 42, core::atomic::MemoryOrder::AcqRel);
}

void test_illegal_fence_order_0() {
    core::atomic::atomic_fence(core::atomic::MemoryOrder::Relaxed);
}

