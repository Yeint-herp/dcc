=== FILE: main.dc ===
module main;
import core::atomic;

void test_illegal_load_order_2(volatile i32* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::Release);
}

void test_illegal_load_order_3(volatile i32* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::AcqRel);
}

void test_illegal_store_order_1(volatile i32* p) {
    core::atomic::atomic_store(p, 42, core::atomic::MemoryOrder::Acquire);
}

void test_illegal_store_order_3(volatile i32* p) {
    core::atomic::atomic_store(p, 42, core::atomic::MemoryOrder::AcqRel);
}

void test_illegal_fence_order_0() {
    core::atomic::atomic_fence(core::atomic::MemoryOrder::Relaxed);
}

