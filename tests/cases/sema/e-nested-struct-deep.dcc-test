module m;

struct Level1 {
    i32 v;
}

struct Level2 {
    Level1 l1;
    i32 v;
}

struct Level3 {
    Level2 l2;
    i32 v;
}

void f(Level3 d) {
    sizeof(Level1);
    sizeof(Level2);
    sizeof(Level3);
    alignof(Level1);
    alignof(Level2);
    alignof(Level3);
    offsetof(Level1, v);
    offsetof(Level2, l1);
    offsetof(Level2, v);
    offsetof(Level3, l2);
    offsetof(Level3, v);
    d.l2.l1.v;
}

