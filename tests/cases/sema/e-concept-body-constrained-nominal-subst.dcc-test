=== FILE: main.dc ===
module m;

using IsInt(T) = compiles(T x) {
    x + 1;
};

struct NoAdd {}

struct Box(T) if IsInt(T) {
    T value;
}

struct Maker {}

Box(i32) make_box(Maker m) {
    Box(i32) b;
    return b;
}

using MakesBox(M, E) = compiles(M m) {
    Box(E) b = m.make_box();
};

void require_box(M, E)(M m, E e) if MakesBox(M, E) {}

void positive_substitutes_concept_param_before_resolving_box() {
    Maker m;
    i32 value = 1;
    require_box(m, value);
}

void negative_rejects_box_when_substituted_param_fails_constraint() {
    Maker m;
    NoAdd bad;
    require_box(m, bad);
}

