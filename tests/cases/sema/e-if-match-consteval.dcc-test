module m;

i64 taken_if() {
    return if true { 1 } else { 2 };
}

i64 equal_if(bool cond) {
    return if cond { 3 } else { 3 };
}

i64 literal_match() {
    return match 2 {
        1 => 10,
        2 => 20,
        _ => 30,
    };
}

i64 range_match() {
    return match 5 {
        1..=3 => 10,
        4..=6 => 20,
        _ => 30,
    };
}

i64 wildcard_match() {
    return match 9 {
        1 => 10,
        _ => 30,
    };
}

i64 binding_match() {
    return match 7 {
        x => 40,
        _ => 50,
    };
}

i64 complex() {
    return if true && !false {
        match 2 {
            1 => 10,
            2 => 20,
            _ => 30,
        } as i64
    } else {
        0
    };
}

