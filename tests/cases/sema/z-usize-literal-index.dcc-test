module m;

void test_array_literal_index(i32[10] arr) {
    arr[0];
    arr[1];
}

void test_slice_literal_index([]i32 s) {
    s[0];
}

void test_pointer_literal_index(i32* p) {
    p[0];
}

void test_range_literal_bounds(i32[10] arr) {
    arr[0..5];
}

void test_range_var_start(i32[10] arr, usize n) {
    arr[0..n];
}

void test_range_var_end(i32[10] arr, usize n) {
    arr[n..10];
}

void test_standalone_range_expr(i32[10] arr, usize n) {
    0..n;
}

void test_for_in_range_with_len([]i32 s) {
    for i in 0..s.len {
        usize x = i;
    }
}

void test_const_range_slice(i32[10] arr) {
    arr[0..10];
}

void test_mismatched_non_literal_bounds(i32[10] arr, i32 a, u64 b) {
    arr[a..b];
}

