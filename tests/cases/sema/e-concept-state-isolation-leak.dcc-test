=== FILE: main.dc ===
module m;

struct WithValue {
    i32 value;
}

struct WithoutValue {
}

using HasValue(T) = compiles(T x) {
    x.value;
};

void constrained_fn(T)(T x) if HasValue(T) {}

void test() {
    WithoutValue wv;

    static if compiles {
        constrained_fn(wv);
    } {
    }

    WithValue wv2;
    constrained_fn(wv2);
}
