module m;

struct Handler(T) {
    T value;
}

void process(T, U...)(Handler(T) self, U args) {
    sizeof...(U);
}

void test_basic_pack() {
    Handler(i32) h;
    h.process(1, 2);
}

void test_hetero_pack() {
    Handler(i32) h;
    h.process(1, 3.14);
}

void test_zero_pack() {
    Handler(i32) h;
    h.process();
}

void test_large_pack() {
    Handler(i32) h;
    h.process(1, 2, 3, 4);
}

struct S {
    i32 value;
}

i32 add(S s, i32 x) {
    return x;
}

i32 test_non_variadic_ufcs(S s) {
    return s.add(1);
}

void foo(T, U...)(T x, U args) {}

void test_direct_variadic() {
    foo!(i32)(1, 2, 3);
}

