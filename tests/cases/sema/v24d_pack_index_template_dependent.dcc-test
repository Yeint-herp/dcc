=== FILE: main.dc ===
module m;

void take_i32(i32 a) {}

void array_first(T)(T x) {
    take_i32(x[0]);
}

void pack_first(T...)(T args) {
    take_i32(args.0);
}

void caller() {
    i32[3] arr_val = {1, 2, 3};
    array_first!(i32[3])(arr_val);
    pack_first!(i32, f64)(0, 1.0);
}

