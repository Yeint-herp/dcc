=== FILE: main.dc ===
module m;

void take_i32(i32 a) {}

void indexed_call(T...)(T args) {
    static for i in 0..sizeof...(T) {
        take_i32(args[i]);
    }
}

void caller() {
    indexed_call!(i32, i32)(10, 20);
}

