module m;

void test_postfix_int(i32 x) {
    x++;
}

void test_postfix_float(f64 y) {
    y--;
}

void test_prefix_int(i32 z) {
    ++z;
}

void test_prefix_float(f64 w) {
    --w;
}

void test_postfix_ptr(i32* p) {
    p++;
}

void test_prefix_ptr(i32* q) {
    ++q;
}

