module m;

using IsInt(T) = compiles(T x) {
    x + 1;
};

struct NoAdd {}

struct X(T) if IsInt(T) {
    T val;
}

void test_var() {
    X(NoAdd) bad;
}

struct Y(T) if IsInt(T) {
    T val;
}

void test_nested() {
    X(Y(NoAdd)) deep;
}

