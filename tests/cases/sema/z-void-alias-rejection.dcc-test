module test;

using V = void;
@nominal using NV = void;

public struct Box(T) { T val; }

public void alias_local() { V x; }
public void nominal_local() { NV x; }

public struct AliasStructField { V f; }
public struct NominalStructField { NV f; }

public union AliasUnionField { V f; i32 g; }
public union NominalUnionField { NV f; i32 g; }

public void alias_array() { V[4] arr; }
public void nominal_array() { NV[4] arr; }

public void alias_slice() { []V x; }
public void nominal_slice() { []NV x; }

public void alias_box() { Box(V) b; }
public void nominal_box() { Box(NV) b; }

public V* alias_void_ptr() { return 0 as void*; }
public NV* nominal_void_ptr() { return 0 as void*; }
public void returns_void() {}

public enum Result(T) { Ok(T), }
public void enum_alias_ok() { Result(V) r = Result::Ok; }

