=== FILE: test.dc ===
module m;

using BinOp = i32(*)(i32, i32);

i32 add(i32 a, i32 b) { return a + b; }

BinOp get_op() { return &add; }

void test_assign() {
    BinOp op;
    op = add;
    op = &add;
}

void test_copy() {
    BinOp a = add;
    BinOp b = a;
}

void test_get_op() {
    BinOp op = get_op();
}

void test_call() {
    BinOp op = add;
    i32 r = op(1, 2);
}

