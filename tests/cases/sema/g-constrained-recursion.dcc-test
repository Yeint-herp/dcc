=== FILE: main.dc ===
module m;

struct NoAdd {}

using SelfRef(T) = compiles(T x) {
    Foo(i32) y;
};

struct Foo(T) if SelfRef(T) {
    T val;
}

void test_self_ref() {
    Foo(i32) f;
}

using ConceptA(T) = compiles(T x) {
    StructB(i32) y;
};

using ConceptB(T) = compiles(T x) {
    StructA(i32) y;
};

struct StructA(T) if ConceptA(T) {
    T val;
}

struct StructB(T) if ConceptB(T) {
    T val;
}

void test_mutual() {
    StructA(i32) a;
}

using IsInt(T) = compiles(T x) {
    x + 1;
};

struct Plain(T) if IsInt(T) {
    T val;
}

void test_positive() {
    Plain(i32) p;
    p.val = 42;
}

