=== FILE: main.dc ===
module m;

struct Point {
    i32 x;
    i32 y;
}

void test_postfix_rvalue() {
    5++;
}

void test_prefix_rvalue() {
    ++10;
}

void test_postfix_non_numeric(Point p) {
    p++;
}

void test_prefix_non_numeric(Point q) {
    ++q;
}

void test_postfix_bool(bool b) {
    b++;
}

void test_prefix_bool(bool c) {
    ++c;
}

