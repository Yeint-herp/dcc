module m;

void take_i32(i32 a) {}
void take_f64(f64 a) {}

void mixed(T...)(i32[2] arr, T args) {
    take_i32(arr[0]);
    take_i32(args.0);
    take_f64(args.1);
    take_i32(arr[1]);
}

void caller() {
    i32[2] arr_val = {10, 20};
    mixed!(i32, f64)(arr_val, 0, 1.0);
}

