=== FILE: fmt.dc ===
module fmt;

public enum FormatArg {
    Str([]const char),
    Int(i32),
}

using WritableInto(T) = compiles(T x) {
    x.write("H");
    x.write('H');
};

public void println(T)(T out, []const char msg) if WritableInto(T) {
    FormatArg[0] empty;
    out.format_impl(msg, empty);
}

public void format_impl(T)(T out, []const char fmt, []const FormatArg args) if WritableInto(T) {}

