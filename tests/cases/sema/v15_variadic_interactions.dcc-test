module m;

void target(i32 a, i64 b) {}

void forward(T...)(T x) {
    target(x...);
}

void id(T...)(T x) {
    sizeof...(T);
}

void caller() {
    forward!(i32, i64)(0, 1);
    id!(i32)(1);
    id!(i32)(2);
    id!(i64)(3);
}

