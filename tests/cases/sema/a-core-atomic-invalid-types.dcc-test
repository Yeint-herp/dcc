=== FILE: main.dc ===
module main;
import core::atomic;

void test_float_type(volatile f32* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::Relaxed);
}

struct S { i32 x; }

void test_struct_type(volatile S* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::Relaxed);
}

void test_ptr_rmw(volatile (volatile i32*)* pp, volatile i32* vp) {
    core::atomic::atomic_fetch_add(pp, vp, core::atomic::MemoryOrder::Relaxed);
}

=== EXPECT-ERRORS ===
main.dc:5: atomic intrinsic does not support float type `f32`
main.dc:11: atomic intrinsic does not support aggregate type `S`
main.dc:15: atomic RMW operations on pointer type `volatile i32*` are not supported
