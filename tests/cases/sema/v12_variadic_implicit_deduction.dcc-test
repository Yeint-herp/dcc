=== FILE: main.dc ===
module m;

void foo(T...)(T x) {
    sizeof...(T);
}

void bar(T, U...)(T first, U rest) {
    sizeof...(T);
    sizeof...(U);
}

void multi(T...)(T x) {
    sizeof...(T);
}

void caller() {
    foo(42);
    foo(3.14);
    foo(1);
    bar(1, 2.0);
    multi(1, 2.0);
    foo!(i32)(42);
    bar!(i32, f64)(1, 2.0);
}

