    return 1;
}

i32 handle(Status s, i32 extra) {
    return 2;
}

i32 test_ok_dispatch() {
    return handle({ 42 });
}

i32 test_err_dispatch() {
    return handle({ false });
}

i32 test_union() {
    Status s = { 99 };
    return 1;
}

