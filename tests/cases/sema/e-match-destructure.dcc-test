=== FILE: main.dc ===
module m;

enum Result {
    Ok(i32),
    Err(i32),
    Cancelled,
}

struct Point {
    i32 x;
    i32 y;
}

i64 f(Result res) {
    return match res {
        Result::Ok(inner) => inner as i64,
        Result::Err(code) => code as i64,
        Result::Cancelled => 3,
    };
}

i64 g(Point p) {
    return match p {
        Point { x, y } => (x + y) as i64,
        Point { x, _ } => 5,
    };
}

