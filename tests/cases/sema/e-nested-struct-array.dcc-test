module m;

struct Point {
    f64 x;
    f64 y;
}

struct Holder {
    Point[3] points;
    i32 tag;
}

void f(Holder h) {
    sizeof(Point);
    sizeof(Holder);
    alignof(Point);
    alignof(Holder);
    offsetof(Point, x);
    offsetof(Point, y);
    offsetof(Holder, points);
    offsetof(Holder, tag);
    h.points[0].x;
}

