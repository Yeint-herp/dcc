module m;

public struct S {
    i32 value;
}

i32 add(S s, i32 x) {
    return s.value + x;
}

T id(T)(T x) {
    return x;
}

void wrong_arity() {
    S s = {1};
    s.add();
}

void wrong_type() {
    S s = {1};
    s.add(true);
}

void receiver_mismatch() {
    i32 x = 1;
    x.add(2);
}

void template_mismatch() {
    S s = {1};
    s.id(1, 2);
}

