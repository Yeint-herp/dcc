=== FILE: m.dc ===
module m;

struct Vec3 { f32 x; f32 y; f32 z; }

@nominal using NominalVec3 = Vec3;

NominalVec3 origin() { return NominalVec3{0.0, 0.0, 0.0}; }

f32 read_x(NominalVec3 v) { return v.x; }

