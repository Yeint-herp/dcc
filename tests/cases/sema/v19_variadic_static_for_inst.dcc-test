module m;

void sf_empty(T...)(T x) {
    static for item in x {
        item;
    }
}

void sf_single(T...)(T x) {
    static for item in x {
        item;
    }
}

void sf_multi(T...)(T x) {
    static for item in x {
        item;
    }
}

void caller() {
    sf_empty!()();
    sf_single!(i32)(0);
    sf_multi!(i32, i64, f64)(0, 1, 2.0);
}

