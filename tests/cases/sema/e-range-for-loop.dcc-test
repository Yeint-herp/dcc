module m;

void test_for_range() {
    for i in 0..10 {
        i32 x = i;
    }
}

void test_for_range_inclusive() {
    for i in 1..=5 {
        i32 x = i;
    }
}

void test_for_range_var(i32 start, i32 end) {
    for i in start..end {
        i32 x = i;
    }
}

void test_for_array(i32[3] arr) {
    for i in arr {
        i32 x = i;
    }
}

void test_for_slice([]i32 sl) {
    for i in sl {
        i32 x = i;
    }
}

