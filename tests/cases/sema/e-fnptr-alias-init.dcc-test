=== FILE: test.dc ===
module m;

using BinOp = i32(*)(i32, i32);

i32 add(i32 a, i32 b) { return a + b; }

void test_alias_addr() {
    BinOp op = &add;
}

void test_alias_implicit() {
    BinOp op = add;
}

