module test;

public enum Result(T, E) { Ok(T), Err(E), }

public void test_reject_ok_pattern(Result(void, i32) x) {
    match x {
        Result::Ok(v) => {},
        Result::Err(e) => {},
    };
}

public void test_reject_ok_construct() {
    Result(void, i32) r = Result::Ok(42);
}

