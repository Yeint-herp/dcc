module m;

enum SinglePayload {
    @implicit_construction A(i32),
    @implicit_construction B(bool),
    NoPayload,
}

enum MultiPayload {
    @implicit_construction Pair(i32, i32),
    @implicit_construction Triple(i32, i32, i32),
    Empty,
}

enum MixedAttr {
    @implicit_construction WithPayload(bool),
    NoPayloadNeither,
}

i32 test_single_payload_1() {
    SinglePayload a = { 1 };
    return 1;
}

bool test_single_payload_2() {
    SinglePayload b = { true };
    return true;
}

i32 test_mixed_attr() {
    MixedAttr m = { true };
    return 1;
}

i32 test_func_arg(SinglePayload s) {
    return 1;
}

i32 call_with_brace() {
    return test_func_arg({ 99 });
}

SinglePayload return_brace() {
    return { true };
}

