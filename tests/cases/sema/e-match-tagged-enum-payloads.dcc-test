=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

struct PairFields {
    Point point;
    Maybe maybe;
}

enum Node {
    Leaf(i32),
    Pair(PairFields),
    Ptr(i32*),
    Bytes(u8[4]),
    Empty,
}

i64 score(Node node) {
    return match node {
        Node::Leaf(0) => 10,
        Node::Leaf(value) => value as i64,
        Node::Pair(PairFields { point => Point { x, y }, maybe => Maybe::Some(extra) }) => (x + y + extra) as i64,
        Node::Pair(PairFields { point => Point { x => left, y => right }, maybe => Maybe::None }) => (left + right) as i64,
        Node::Pair(_) => 7,
        Node::Ptr(ptr) => 8,
        Node::Bytes(_) => 9,
        Node::Empty => 0,
    };
}

