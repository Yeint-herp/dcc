=== FILE: main.dc ===
module m;

struct WithValue {
    i32 value;
}

struct WithoutValue {
}

using HasValue(T) = compiles(T x) {
    x.value;
};

void constrained_fn(T)(T x) if HasValue(T) {}

void test() {
    WithValue good;
    constrained_fn(good);

    WithoutValue bad;
    static if compiles {
        constrained_fn(bad);
    } {
    }

    constrained_fn(good);
}

=== EXPECT-BODY ===
Module m
  Func constrained_fn diverging=false
    Param x type=T storage=param offset=0 index=0
    Body
  Func test diverging=false
    Body
      Var good type=WithValue storage=local offset=0
      Call [type=void const=<none> decl=constrained_fn spec=constrained_fn]
        Ident constrained_fn [type=<unresolved> const=<none>]
        Ident good [type=WithValue const=<none> lvalue decl=good]
      Var bad type=WithoutValue storage=local offset=4
      StaticIf taken=1
        Compiles [type=bool const=false constant]
        Body
          Call [type=<error> const=<none>]
            Ident constrained_fn [type=<unresolved> const=<none>]
            Ident bad [type=WithoutValue const=<none> lvalue decl=bad]
      Call [type=void const=<none> decl=constrained_fn spec=constrained_fn]
        Ident constrained_fn [type=<unresolved> const=<none>]
        Ident good [type=WithValue const=<none> lvalue decl=good]
