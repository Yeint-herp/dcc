module m;

struct Vec3 {
    i32 x;
    i32 y;
    i32 z;
}

enum TriState {
    @implicit_construction On(i32),
    @implicit_construction Off(bool),
    @implicit_construction Maybe(f32),
}

i32 consume(TriState ts) {
    return 40;
}

i32 consume(Vec3 v) {
    return 10;
}

i32 consume(i32[3] arr) {
    return 20;
}

i32 consume([]i32 sl) {
    return 30;
}

i32 test_enum_bool_dispatch() {
    return consume({ false });
}

i32 test_struct_dispatch() {
    return consume({ 1, 2, 3 });
}

i32 test_array_dispatch() {
    i32[3] arr = { 4, 5, 6 };
    return consume(arr);
}

