module m;

void test_range_int() {
    1..10;
}

void test_range_inclusive_int() {
    1..=10;
}

void test_range_char() {
    'a'..'z';
}

void test_range_variable(i32 lo, i32 hi) {
    lo..hi;
}

void test_range_expr() {
    1 + 2..3 * 4;
}

