module lib;

public struct Box(T) {
    T value;
}

public enum Wrap(T) : u8 {
    None,
    Some(T),
}

=== FILE: main.dc ===
module main;

public import lib;

public using MainBox = lib::Box(i32);
public using MainWrap = lib::Wrap(i32);

public using BoxAlias = MainBox;
public using WrapAlias = MainWrap;

public lib::Box(i32) direct;
public MainBox alias_box;
public MainBox via_alias;
public MainWrap wrap;

