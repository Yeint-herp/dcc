module std::io;

public enum Result(T, E) { Ok(T), Err(E), }

public struct IoError {}
public struct BufferWriter {}

public Result(void, IoError) write(BufferWriter w, []const u8 data) {
    return Result::Ok;
}

=== FILE: std/fmt.dc ===
module std::fmt;

import std::io;
public import std::io;
using io::*;

public using Writer(W, E) = compiles(W w, []const u8 data) {
    Result(void, E) r = w.write(data);
};

public Result(void, E) write_str(W, E)(W writer, []const u8 data) if Writer(W, E) {
    Result(void, E) r = writer.write(data);
    return r;
}

