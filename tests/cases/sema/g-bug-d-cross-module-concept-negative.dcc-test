module main;

import std::fmt;

struct OtherError {}

void entry() {
    std::fmt::BufferWriter w;
    u8[0] bytes;
    std::fmt::Result(void, OtherError) r =
        std::fmt::write_str!(std::fmt::BufferWriter, OtherError)(w, bytes);
}

