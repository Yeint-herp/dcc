=== FILE: lib/status.dc ===
module lib::status;
public enum status : u64 {
    Success = 0,
    BufferTooSmall = 0x8000000000000005,
    LoadError = 0x8000000000000001,
}

=== FILE: lib/protocols/file.dc ===
module lib::protocols::file;
public import lib;
public import lib::status;

public void* read_all(u64* out_size) {
    u64 to_read = 42;
    status::status st = 0 as status::status;

    if st != status::status::BufferTooSmall && st != status::status::Success {
        return null;
    }

    st = 1 as status::status;
    if st != status::status::Success {
        return null;
    }

    *out_size = to_read;
    return null;
}

