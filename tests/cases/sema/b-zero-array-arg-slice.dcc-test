module main;

// Test 1: zero-length fixed array passed to slice param (non-generic)
enum FormatArg {
    Str([]const char),
}

void f([]const FormatArg args) {}

void test_zero_array_to_slice() {
    FormatArg[0] empty;
    f(empty);
}

// Test 2: zero-length fixed array passed to slice param via generic UFCS
using WritableInto(T) = compiles(T x) {
    x.write("H");
    x.write('H');
};

void format_impl(T)(T out, []const char fmt, []const FormatArg args) if WritableInto(T) {}

void println(T)(T out, []const char msg) if WritableInto(T) {
    FormatArg[0] empty;
    out.format_impl(msg, empty);
}

struct MyOut { i32 fd; }

void write(MyOut o, []const char s) {}
void write(MyOut o, char c) {}

void test_generic_ufcs_zero_array() {
    MyOut out;
    out.println("hello");
}

// Test 3: verify non-zero arrays still work
void test_nonzero_array_to_slice() {
    FormatArg[1] one;
    f(one);
}

// Test 4: zero-length builtin array to slice
void test_zero_builtin_array_to_slice() {
    i32[0] empty;
    []const i32 s = empty;
}

