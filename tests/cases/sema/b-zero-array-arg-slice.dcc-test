module main;

enum FormatArg {
    Str([]const char),
}

void f([]const FormatArg args) {}

void test_zero_array_to_slice() {
    FormatArg[0] empty;
    f(empty);
}

using WritableInto(T) = compiles(T x) {
    x.write("H");
    x.write('H');
};

void format_impl(T)(T out, []const char fmt, []const FormatArg args) if WritableInto(T) {}

void println(T)(T out, []const char msg) if WritableInto(T) {
    FormatArg[0] empty;
    out.format_impl(msg, empty);
}

struct MyOut { i32 fd; }

void write(MyOut o, []const char s) {}
void write(MyOut o, char c) {}

void test_generic_ufcs_zero_array() {
    MyOut out;
    out.println("hello");
}

void test_nonzero_array_to_slice() {
    FormatArg[1] one;
    f(one);
}

void test_zero_builtin_array_to_slice() {
    i32[0] empty;
    []const i32 s = empty;
}

