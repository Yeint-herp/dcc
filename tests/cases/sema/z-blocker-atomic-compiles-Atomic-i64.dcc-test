=== FILE: main.dc ===
module m;

import core::atomic;

using AtomicLoadable(T) = compiles(core::atomic::Atomic(T)* p) {
    core::atomic::atomic_load(p, core::atomic::MemoryOrder::Relaxed);
};

void accept(T)(core::atomic::Atomic(T)* p) if AtomicLoadable(T) {}

void test() {
    core::atomic::Atomic(i64) cell;
    core::atomic::Atomic(i64)* p = &cell;
    accept(p);
}
