=== FILE: test.dc ===
module m;

using BinOp = i32(*)(i32, i32);

i32 add(i32 a, i32 b) { return a + b; }

i32 apply(BinOp f, i32 a, i32 b) { return f(a, b); }

BinOp make_add() { return &add; }

void test_pass() {
    i32 r = apply(&add, 1, 2);
}

void test_return() {
    BinOp f = make_add();
}

