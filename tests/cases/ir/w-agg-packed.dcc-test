module test;

@packed
public struct PackedS {
    u64 a;
    u8 b;
    u32 c;
}

public u64 get_a(PackedS p) { return p.a; }
public u8  get_b(PackedS p) { return p.b; }
public u32 get_c(PackedS p) { return p.c; }

