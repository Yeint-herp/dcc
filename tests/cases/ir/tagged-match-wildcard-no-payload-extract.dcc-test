module test;

public struct Large {
    u64 a;
    u64 b;
    u64 c;
    u64 d;
}

public enum Status {
    OK,
    Data(Large),
    Err(i32),
}

public i32 f(Status s) {
    return match s {
        Status::OK => 0,
        Status::Data(_) => 1,
        Status::Err(e) => e,
    };
}

