=== FILE: test.dc ===
module test;

public i32 defer_simple() {
    i32 x = 0;
    defer x = 1;

    return x;
}

public i32 defer_multi() {
    i32 x = 0;
    defer x = 1;
    defer x = 2;

    return x;
}

public i32 defer_early_return(i32 n) {
    i32 x = 0;
    defer x = x + 1;

    if (n > 0) { return x; }
    x = 100;

    return x;
}

public i32 defer_break(i32 n) {
    i32 x = 0;

    while (x < n) {
        defer x = 1;

        if (x > 5) { break; }
        x = x + 1;
    }

    return x;
}

public i32 defer_nested_scopes(i32 n) {
    i32 x = 0;

    if (n > 0) {
        defer x = 10;

        if (n > 1) {
            defer x = 100;
        }
    }

    return x;
}

