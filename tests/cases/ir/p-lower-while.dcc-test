=== FILE: test.dc ===
module test;

public i32 while_simple(i32 n) {
    i32 i = 0;
    while (i < n) { i = i + 1; }

    return i;
}

public i32 while_break(i32 n) {
    i32 i = 0;
    while (i < n) { if (i == 5) { break; } i = i + 1; }

    return i;
}

public i32 while_continue(i32 n) {
    i32 i = 0;
    while (i < n) { i = i + 1; if (i < 3) { continue; } i = i + 1; }

    return i;
}

public i32 while_true_break(i32 n) {
    i32 i = 0;

    while (true) {
        i = i + 1;
        if (i == n) { break; }
    }

    return i;
}

