module test;

public u32 uadd(u32 a, u32 b) { return a + b; }
public u32 urem(u32 a, u32 b) { return a % b; }
public u32 ushl(u32 a, u32 b) { return a << b; }
public u32 ushr(u32 a, u32 b) { return a >> b; }
public bool ueq(u32 a, u32 b) { return a == b; }
public bool ult_fn(u32 a, u32 b) { return a < b; }
public bool ule(u32 a, u32 b) { return a <= b; }
public bool ugt(u32 a, u32 b) { return a > b; }
public bool uge(u32 a, u32 b) { return a >= b; }

