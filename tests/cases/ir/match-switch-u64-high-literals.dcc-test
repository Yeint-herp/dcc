module test;

public i32 high_literals(u64 v) {
    return match v {
        0x8000_0000_0000_0000 => 1,
        0x8000_0000_0000_0001 => 2,
        0x8000_0000_0000_0002 => 3,
        0x8000_0000_0000_0003 => 4,
        _ => 99,
    };
}

