=== FILE: test.dc ===
module test;

public i32 next(i32 i) { return i + 1; }

public i32 sum_to(i32 n) {
    i32 s = 0;

    for i32 i = 0; i < n; i = next(i) {
        s = s + i;
    }

    return s;
}

