module test;

public bool short_and(bool a, bool b) {
    return a && b;
}

public bool short_or(bool a, bool b) {
    return a || b;
}

public bool short_and_in_if(bool a, bool b) {
    bool r = false;
    if (a && b) { r = true; }

    return r;
}

