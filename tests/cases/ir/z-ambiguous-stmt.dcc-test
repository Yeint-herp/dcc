module win::common;

public struct ListEntry { u64 Flink; u64 Blink; }
public struct UnicodeString { u16 Length; u16 MaximumLength; u64 Buffer; }

public ListEntry* next_entry(ListEntry* current, ListEntry* list_head) {
    ListEntry* next = current.Flink as ListEntry*;
    if next == list_head { return null; }
    return next;
}

