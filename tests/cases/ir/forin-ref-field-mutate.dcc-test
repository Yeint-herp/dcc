=== FILE: test.dc ===
module test;
public struct Point { i32 x; i32 y; }

public i32 f() {
    Point[2] arr;
    arr[0].x = 1;
    arr[0].y = 2;
    arr[1].x = 3;
    arr[1].y = 4;

    for &pt in arr {
        pt.y = pt.x + 10;
    }

    return arr[0].y + arr[1].y;
}

