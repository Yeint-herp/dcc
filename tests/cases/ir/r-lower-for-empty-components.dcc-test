module test;

public void test_empty_all_parens() {
    for (;;) {
        break;
    }
}

public void test_empty_all_parenless() {
    for ;; {
        break;
    }
}

public void test_empty_init_and_update(i32 n) {
    i32 x = 0;
    for (; n > 0;) {
        break;
    }
}

public void test_empty_init_and_cond() {
    i32 n = 0;
    for (;; n = n - 1) {
        break;
    }
}

public void test_empty_cond_and_update() {
    i32 n = 0;
    for (n = 42;;) {
        break;
    }
}

public void test_nested_empty_loops() {
    for (;;) {
        for (;;) {
            break;
        }
        break;
    }
}

public void test_continue_in_empty_loop() {
    i32 i = 0;
    for (;;) {
        i = i + 1;
        if (i > 10) {
            break;
        }
        continue;
    }
}

