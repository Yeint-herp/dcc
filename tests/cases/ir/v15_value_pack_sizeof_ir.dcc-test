  %0 = call fn(@_DC0S1.4.test8.sz_three1i8ui64uX3vIi16u1vIi16u2vIi16u3)(u8 #0) -> u64
  ret void
}

linkonce_odr u64@_DC0S1.4.test8.sz_three1i8ui64uX3vIi16u1vIi16u2vIi16u3(u8) {
