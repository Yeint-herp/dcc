module test;

public i32 or_high(u64 v) {
    return match v {
        0x8000_0000_0000_0000 | 0x8000_0000_0000_0001 => 10,
        0x8000_0000_0000_0002 | 0x8000_0000_0000_0003 => 20,
        _ => 99,
    };
}

