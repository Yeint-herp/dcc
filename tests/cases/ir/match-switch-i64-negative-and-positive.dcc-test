module test;

public i32 neg_pos(i64 v) {
    return match v {
        0xFFFF_FFFF_FFFF_FFFF => 1,
        0x0000_0000_0000_0000 => 2,
        0x0000_0000_0000_0001 => 3,
        0x0000_0000_0000_0002 => 4,
        _ => 99,
    };
}

