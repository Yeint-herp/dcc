module test;

public enum Result {
    Ok(i32),
    Err(i32),
}

public i32 f(Result r) {
    return match r {
        Result::Ok(x) if x > 0 => x,
        Result::Ok(x) => -x,
        Result::Err(e) => e,
    };
}

