module test;

public i32 sparse_high(u64 v) {
    return match v {
        0x8000_0000_0000_0000 => 1,
        0x9000_0000_0000_0000 => 2,
        0xA000_0000_0000_0000 => 3,
        0xB000_0000_0000_0000 => 4,
        _ => 99,
    };
}

