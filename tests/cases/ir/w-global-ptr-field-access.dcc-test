=== FILE: test.dc ===
module test;

struct Point {
    i64 x;
    i64 y;
}

using PtrPoint = Point*;

Point gp;
Point* gpp;

public i64 local_struct_field(i64 a) {
    Point p = {x = a, y = 2};
    p.x = 42;
    return p.x;
}

public i64 local_ptr_field(i64 a) {
    Point p = {x = a, y = 2};
    PtrPoint pp = &p;
    pp.x = 42;
    return pp.x;
}

public i64 global_struct_read() {
    return gp.x;
}

public i64 global_ptr_read() {
    return gpp.x;
}
public void global_ptr_write() {
    gpp.x = 42;
}

