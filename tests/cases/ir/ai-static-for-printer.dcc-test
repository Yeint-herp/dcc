module test;

public struct ConsoleWriter {
}

public void write(ConsoleWriter* c, i32 val) {}
public void write(ConsoleWriter* c, i64 val) {}

using WritableInto(W) = compiles(W x) {
    x.write(1 as i32);
    x.write(2 as i64);
};

void print(W, T...)(W out, T args) if WritableInto(W) {
    static for arg in args {
        out.write(arg);
    }
}

public void caller() {
    ConsoleWriter cw;
    i32 a = 1;
    i64 b = 2;
    print(cw, a, b);
}

