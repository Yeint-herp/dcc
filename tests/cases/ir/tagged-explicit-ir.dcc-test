module test;

public enum Status {
    Ok = 0,
    Warning(i32) = 100,
    Error = 200,
}

public Status make_ok() {
    return Status::Ok;
}

public Status make_warning(i32 x) {
    return Status::Warning(x);
}

public Status make_error() {
    return Status::Error;
}

public i32 check(Status s) {
    return match s {
        Status::Ok => 1,
        Status::Warning(x) => 2,
        Status::Error => 3,
    };
}
