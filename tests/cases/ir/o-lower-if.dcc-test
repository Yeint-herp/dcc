module test;

public i32 if_plain(i32 x) {
    i32 r = 0;
    if (x) { r = 1; }

    return r;
}

public i32 if_else(i32 x) {
    i32 r = 0;
    if (x) { r = 1; } else { r = 2; }

    return r;
}

public i32 if_expr_phi(i32 x) {
    return if (x) { 10 } else { 20 };
}

public i32 if_one_returns(i32 x) {
    return if (x) { 10 } else { return 20; };
}

public i32 if_both_return(i32 x) {
    if (x) { return 10; } else { return 20; }
}

