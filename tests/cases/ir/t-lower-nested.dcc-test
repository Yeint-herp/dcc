=== FILE: test.dc ===
module test;

public i32 nested_loop(i32 n) {
    i32 r = 0;
    i32 i = 0;

    while i < n {
        i32 j = 0;

        while j < i {
            r = r + 1;
            j = j + 1;
        }

        i = i + 1;
    }

    return r;
}

public i32 nested_loop_defer(i32 n) {
    i32 x = 0;

    while x < n {
        defer x = x + 1;

        if (x > 2) { return x; }
        x = x + 1;
    }

    return x;
}

