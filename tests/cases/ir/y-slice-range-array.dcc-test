module test;

public []i64 array_range(i64[5] arr) {
    return arr[1..3];
}

public []i64 omit_start(i64[5] arr) {
    return arr[..3];
}

public []i64 omit_end(i64[5] arr) {
    return arr[1..];
}

public []i64 full_slice(i64[5] arr) {
    return arr[..];
}

public []i64 inclusive_range(i64[5] arr) {
    return arr[1..=3];
}

