=== FILE: test.dc ===
module test;

public struct Point { i32 x; i32 y; }

public i32 f(Point p) {
    match p {
        &pt => {
            pt.x = 42;
        },
    };

    Point[1] arr;
    arr[0].x = 1;
    arr[0].y = 2;

    for &item in arr {
        item.y = item.x + 10;
    }

    return p.x + arr[0].y;
}

