=== FILE: test.dc ===
module test;

public i32 dense_int(i32 v) {
    return match v {
        1 => 10,
        2 => 20,
        3 => 30,
        4 => 40,
        5 => 50,
        6 => 60,
        7 => 70,
        8 => 80,
        _ => 99,
    };
}

public i32 dense_char(char c) {
    return match c {
        'a' => 1,
        'b' => 2,
        'c' => 3,
        'd' => 4,
        'e' => 5,
        _ => 99,
    };
}

public i32 dense_ranges(i32 v) {
    return match v {
        0..=3 => 1,
        4..=7 => 2,
        8..=11 => 3,
        12..=15 => 4,
        _ => 99,
    };
}

public i32 dense_or_contiguous(i32 v) {
    return match v {
        1 | 2 | 3 | 4 => 10,
        5 => 20,
        _ => 99,
    };
}

