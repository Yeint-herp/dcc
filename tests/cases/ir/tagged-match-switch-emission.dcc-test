module test;

public enum Color {
    Red,
    Green,
    Blue,
    Yellow,
    Purple,
    Other(i32),
}

public i32 f(Color c) {
    return match c {
        Color::Red => 1,
        Color::Green => 2,
        Color::Blue => 3,
        Color::Yellow => 4,
        Color::Purple => 5,
        Color::Other(_) => 6,
    };
}

