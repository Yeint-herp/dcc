module test;

public struct Box(T) {
    T value;
}

public i32 test() {
    Box(i32) b;
    b.value = 42;
    return b.value;
}

public Box(Box(i32)) make_nested() {
    Box(Box(i32)) b;
    Box(i32) inner;
    inner.value = 42;
    b.value = inner;
    return b;
}

