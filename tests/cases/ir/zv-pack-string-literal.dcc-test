module test;

i32 take_slice([]const char v) { return 42; }

i32 fmt_char(T...)(T args) {
    i32 result = 0;
    static for arg in args {
        result = take_slice(arg);
    }

    return result;
}

public i32 test_char() {
    return fmt_char("hello");
}

