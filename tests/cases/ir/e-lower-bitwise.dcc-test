module test;

public i32 band(i32 a, i32 b) { return a & b; }
public i32 bor(i32 a, i32 b) { return a | b; }
public i32 bxor(i32 a, i32 b) { return a ^ b; }
public i32 shl(i32 a, i32 b) { return a << b; }
public i32 ashr(i32 a, i32 b) { return a >> b; }

