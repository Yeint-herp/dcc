module test;

public f64 fadd(f64 a, f64 b) { return a + b; }
public f64 fsub(f64 a, f64 b) { return a - b; }
public f64 fmul(f64 a, f64 b) { return a * b; }
public f64 fdiv(f64 a, f64 b) { return a / b; }
public f64 frem(f64 a, f64 b) { return a % b; }
public bool feq(f64 a, f64 b) { return a == b; }
public bool fne(f64 a, f64 b) { return a != b; }
public bool flt(f64 a, f64 b) { return a < b; }
public bool fle(f64 a, f64 b) { return a <= b; }
public bool fgt(f64 a, f64 b) { return a > b; }
public bool fge(f64 a, f64 b) { return a >= b; }

