module test;

public struct Big {
    i64 a;
    i64 b;
}

public enum Data {
    Empty,
    Value(Big),
}

public Data make_empty() {
    return Data::Empty;
}

public Data make_value(i64 a, i64 b) {
    Big val = {a = a, b = b};
    return Data::Value(val);
}

