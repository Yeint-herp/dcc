=== FILE: test.dc ===
module test;

public i32 few_arms(i32 v) {
    return match v {
        1 | 2 => 10,
        3 => 20,
        _ => 99,
    };
}

public i32 sparse_wide(i32 v) {
    return match v {
        1 => 10,
        50 => 20,
        100 => 30,
        200 => 40,
        _ => 99,
    };
}

