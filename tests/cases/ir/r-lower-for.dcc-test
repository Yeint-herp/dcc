=== FILE: test.dc ===
module test;

public i32 for_basic(i32 n) {
    i32 r = 0;
    i32 i = 0;

    for (i = 0; i < n; i = i + 1) { r = r + i; }

    return r;
}

public i32 for_break(i32 n) {
    i32 r = 0;
    i32 i = 0;

    for i = 0; i < n; i = i + 1 {
        r = r + i;
        if (r > 10) { break; }
    }

    return r;
}

public i32 for_continue(i32 n) {
    i32 r = 0;
    i32 i = 0;

    for i = 0; i < n; i = i + 1 {
        if (i == 0) { continue; }
        r = r + i;
    }

    return r;
}

