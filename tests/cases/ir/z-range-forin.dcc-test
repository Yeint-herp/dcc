=== FILE: test.dc ===
module test;

public usize for_in_range_len([]i32 s) {
    usize total = 0;
    for i in 0..s.len {
        total += i;
    }
    return total;
}

public usize for_in_range_const() {
    usize total = 0;
    usize end = 3;
    for i in 0..end {
        total += i;
    }
    return total;
}

public usize for_in_range_inclusive(usize n) {
    usize total = 0;
    for i in 0..=n {
        total += i;
    }
    return total;
}

public i32 for_in_range_signed_excl(i32 end) {
    i32 total = 0;
    for i in 0..end {
        total += i;
    }
    return total;
}

public i32 for_in_range_signed_incl(i32 end) {
    i32 total = 0;
    for i in 0..=end {
        total += i;
    }
    return total;
}

public i32 for_in_range_literal_excl() {
    i32 total = 0;
    for i in 0..10 {
        total += i;
    }
    return total;
}

public i32 for_in_range_literal_incl() {
    i32 total = 0;
    for i in 0..=5 {
        total += i;
    }
    return total;
}

public i32 for_in_range_reverse() {
    i32 total = 0;
    for i in 5..3 {
        total += i;
    }
    return total;
}

public i32 for_in_range_neg_start() {
    i32 total = 0;
    for i in -5..3 {
        total += i;
    }
    return total;
}

