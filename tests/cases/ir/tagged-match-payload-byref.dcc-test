=== FILE: test.dc ===
module test;

public struct Data { i32 field; }

public enum Option {
    None,
    Some(Data),
}

public i32 f(Option o) {
    match o {
        Option::Some(&p) => {
            p.field = 42;
        },
        Option::None => {},
    };

    return match o {
        Option::Some(data) => data.field,
        Option::None => 0,
    };
}

