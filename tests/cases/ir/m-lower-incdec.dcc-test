module test;

public i32 pre_inc() {
    i32 x = 0;
    ++x;

    return x;
}

public i32 post_inc() {
    i32 x = 0;
    x++;

    return x;
}

public i32 pre_dec() {
    i32 x = 0;
    --x;

    return x;
}

