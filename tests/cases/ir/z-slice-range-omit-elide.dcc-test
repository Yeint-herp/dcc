module test;

public []i64 arr_omit_start(i64[5] arr) {
    return arr[..3];
}

public []i64 arr_omit_end(i64[5] arr) {
    return arr[1..];
}

public []i64 arr_full_slice(i64[5] arr) {
    return arr[..];
}

public []i64 slice_omit_start([]i64 s) {
    return s[..3];
}

