module m;

void test_slices(i32[10] arr, i32 start, i32 end) {
    arr[1..3];
    arr[start..end];
    arr[..3];
    arr[1..];
    arr[..];
    arr[1..=3];
    arr[..=3];
    arr[1..=];
    arr[3];
}

