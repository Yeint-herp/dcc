=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

enum Node {
    Leaf(i32),
    Pair(Point, Maybe),
    Empty,
}

void f() {
    match node {
        Node::Leaf(0) => 1,
        Node::Leaf(value) => value,
        Node::Pair(Point { x, y }, Maybe::Some(extra)) => extra,
        Node::Pair(Point { x => left, y => right }, Maybe::None) => left,
        Node::Pair(_, _) => 7,
        Node::Empty => 0,
    };
}

