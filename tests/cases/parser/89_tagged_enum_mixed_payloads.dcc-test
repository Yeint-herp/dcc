=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

enum Packet {
    Int(i32),
    Point(Point),
    Ptr(i32*),
    Bytes(u8[4]),
    Pair(Point, Maybe),
    Empty,
}

void f() {
    match packet {
        Packet::Int(0) => zero(),
        Packet::Int(value) if value > 0 => value,
        Packet::Point(Point { x, y }) => x + y,
        Packet::Pair(Point { x => left, y => right }, Maybe::Some(extra)) => left + right + extra,
        Packet::Pair(_, Maybe::None) => 7,
        Packet::Ptr(ptr) => use(ptr),
        Packet::Bytes(bytes) => use(bytes),
        Packet::Empty => done(),
    };
}

