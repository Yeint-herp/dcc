=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

struct Envelope {
    Maybe maybe;
    Point point;
}

enum Packet {
    Pair(Point, Maybe),
    Wrap(Envelope),
    Empty,
}

void g() {
    static match packet {
        Packet::Pair(Point { x, y }, Maybe::Some(extra)) if x < y && extra > 0 => use(x, y, extra),
        _ => done(),
    }
}

