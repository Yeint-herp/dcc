=== FILE: main.dc ===
module geom;
import std::math;

public struct Point {
    f32 x;
    f32 y;
}

public Point new_point(f32 x, f32 y) {
    return Point { x, y };
}

public f64 length(const Point* self) {
    f64 dx = self.x as f64;
    f64 dy = self.y as f64;
    return std::math::sqrt(dx * dx + dy * dy);
}

