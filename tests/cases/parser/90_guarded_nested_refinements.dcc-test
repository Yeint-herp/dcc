=== FILE: main.dc ===
module m;

enum Maybe {
    Some(i32),
    None,
}

struct Point {
    i32 x;
    i32 y;
}

struct Envelope {
    Maybe maybe;
    Point point;
}

enum Packet {
    Pair(Point, Maybe),
    Wrap(Envelope),
    Empty,
}

void f() {
    match packet {
        Packet::Pair(Point { x, y }, Maybe::Some(extra)) if x < y && extra > 0 => use(x, y, extra),
        Packet::Wrap(Envelope { maybe => Maybe::Some(code), point => Point { x => left, y => right } }) if code > left && right > 0 => use(code, left, right),
        _ => done(),
    };
}

